<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===============================================Shapable样式================================================ -->
    <!-- 圆角图片 -->
    <style name="CDK.Shapeable.ImageRound">
        <item name="cornerSizeTopLeft">25%</item>
        <item name="cornerSizeTopRight">25%</item>
        <item name="cornerSizeBottomRight">25%</item>
        <item name="cornerSizeBottomLeft">25%</item>
    </style>
    <!-- 圆角控件-->
    <style name="CDK.Shapeable.SmoothRound">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">36dp</item>
    </style>
    <!-- 圆角底部弹窗 -->
    <style name="CDK.Shapeable.SmoothRoundTop" parent="CDK.Shapeable.SmoothRound">
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
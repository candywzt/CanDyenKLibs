<resources>
    <!-- ===============================================组件样式================================================== -->
    <!--基类-->
    <style name="CDK.Widget" parent="CDK"/>
    <style name="CDK.Shapeable" parent="CDK"/>
    <!--TextView组件-默认-->
    <style name="CDK.Widget.TextView" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/text_main</item><!--按钮文本颜色-->
    </style>
    <!--Button组件-实心按钮-->
    <style name="CDK.Widget.Button.TextButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/color_textbutton_text</item>
        <item name="android:background">@drawable/bg_textbutton</item>
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:minWidth">36dp</item>
        <item name="backgroundTint">@null</item>
    </style>
    <!--Button组件-空心按钮-->
    <style name="CDK.Widget.Button.TextButton.Outlined" parent="CDK.Widget.Button.TextButton">
        <item name="android:textColor">@color/color_outlinedtextbutton_text</item>
        <item name="android:background">@drawable/bg_outlinedtextbutton</item>
    </style>
    <!--CheckBox组件-默认-->
    <style name="CDK.Widget.CheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:textColor">@color/text_main</item>
    </style>
    <!--RadioButton组件-默认-->
    <style name="CDK.Widget.RadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:textColor">@color/text_main</item>
    </style>
    <!--Chip组件-默认-->
    <style name="CDK.Widget.Chip" parent="Widget.MaterialComponents.Chip.Filter">

    </style>
    <!--EditText组件-实心编辑框-->
    <style name="CDK.Widget.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_edit</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textColorHint">@color/text_deputy</item>
        <item name="android:textCursorDrawable">@drawable/bg_edit_cursor</item>
        <item name="android:padding">8dp</item>
    </style>
    <!--EditText组件-空心编辑框-->
    <style name="CDK.Widget.EditText.Outlined" parent="CDK.Widget.EditText">
        <item name="android:background">@drawable/bg_edit_outlined</item>
    </style>
    <!--Switch组件-默认-->
    <style name="CDK.Widget.Switch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:thumb">@drawable/bg_switch_thumb</item>
        <item name="android:track">@drawable/bg_switch_track</item>
        <item name="android:background">@null</item>
        <item name="android:maxHeight">24dp</item>
        <item name="android:minHeight">24dp</item>
        <item name="android:textOn">""</item>
        <item name="android:textOff">""</item>
    </style>
    <!--Seekbar组件-默认-->
    <style name="CDK.Widget.SeekBar" parent="Widget.AppCompat.SeekBar">
        <item name="android:thumb">@drawable/bg_seekbar_thumb</item><!--拖动按钮背景图-->
        <item name="android:progressDrawable">@drawable/bg_seekbar</item>
        <!--        <item name="android:indeterminateDrawable">@drawable/seekbar_indeterminate</item>-->
        <item name="android:splitTrack">false</item><!--关闭中间割裂-->
        <item name="android:background">@null</item>
        <item name="android:maxHeight">24dp</item>
        <item name="android:minHeight">24dp</item>

    </style>
    <!--RecycleView组件-->
    <!--RecycleView组件-边缘衰减-->
    <style name="CDK.Widget.RecyclerView">
        <item name="android:overScrollMode">ifContentScrolls</item><!--滚动条模式-->
        <item name="android:scrollbars">none</item><!--滚动条方向-->
        <item name="android:requiresFadingEdge">vertical</item><!--边缘衰减方向-->
        <item name="android:fadingEdgeLength">32dp</item><!--边缘衰减长度-->
        <item name="android:colorEdgeEffect">@android:color/transparent</item><!--边缘颜色-->
    </style>
    <!--RecycleView组件-安卓快速滚动条-->
    <style name="CDK.Widget.RecyclerView.ScrollBars" parent="CDK.Widget.RecyclerView">
        <item name="android:scrollbarSize">8dp</item><!--滚动条宽度-->
        <item name="android:scrollbarThumbVertical">@color/main_01</item><!--滚动条背景-->
        <item name="android:scrollbars">vertical</item><!--垂直滚动-->
    </style>
    <!--RecycleView组件-快速滚动条-->
    <style name="CDK.Widget.RecyclerView.FastScrollBars" parent="CDK.Widget.RecyclerView">
        <item name="android:overScrollMode">never</item><!--滚动条模式-->
        <item name="fastScrollEnabled">true</item><!--滚动条拖动-->
        <item name="fastScrollHorizontalThumbDrawable">@drawable/bg_slider_track</item><!--水平滚动块-->
        <item name="fastScrollHorizontalTrackDrawable">@android:color/transparent</item><!--水平滚动块背景-->
        <item name="fastScrollVerticalThumbDrawable">@drawable/bg_slider_track</item><!--竖直滚动块-->
        <item name="fastScrollVerticalTrackDrawable">@android:color/transparent</item><!--竖直滚动块背景-->
    </style>
    <!-- Shapable组件 -->
    <style name="CDK.Widget.Shapeable"/>
    <!-- Shapable组件-默认圆角样式 -->
    <style name="CDK.Widget.Shapeable.DefaultRound">
        <item name="shapeAppearance">@style/CDK.Shapeable.SmoothRound</item>
    </style>
    <!-- Shapable组件-仅上圆角样式 -->
    <style name="CDK.Widget.Shapeable.TopRound">
        <item name="shapeAppearance">@style/CDK.Shapeable.SmoothRoundTop</item>
    </style>

</resources>
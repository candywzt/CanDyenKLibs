<resources>
    <style name="CDK"/>
    <style name="CDK.Theme" parent="Theme.AppCompat.Light">
        <!--        <item name="android:windowSplashScreenBackground">@android:color/background_light</item>-->
        <!--        <item name="android:windowSplashScreenAnimatedIcon">@drawable/aaa</item>-->
        <!-- 状态栏颜色 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- 虚拟键和小白条 -->
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- 状态栏区域显示 -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- 标题栏 -->
        <item name="android:windowTranslucentStatus">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- 主要颜色 -->
        <item name="colorPrimary">@color/main_01</item>
        <item name="colorPrimaryVariant">@color/main_02</item>
        <item name="colorOnPrimary">@color/main_03</item>
        <item name="colorAccent">@color/main_04</item>
        <!-- 次要颜色 -->
        <item name="colorSecondary">@color/main_03</item>
        <item name="colorSecondaryVariant">@color/main_04</item>
        <item name="colorOnSecondary">@color/main_01</item>
        <!-- 其他颜色 -->
        <item name="android:textColorLink">@color/main_01</item>
        <!-- 设置MD视图 -->
        <item name="viewInflaterClass">com.google.android.material.theme.MaterialComponentsViewInflater</item>
        <item name="isMaterialTheme">true</item>
        <!-- 组件样式 -->
        <item name="android:textViewStyle">@style/CDK.Widget.TextView</item>
        <item name="android:buttonStyle">@style/CDK.Widget.Button.TextButton</item>
        <item name="android:switchStyle">@style/CDK.Widget.Switch</item>
        <item name="android:editTextStyle">@style/CDK.Widget.EditText</item>
        <item name="android:checkboxStyle">@style/CDK.Widget.CheckBox</item>
        <item name="android:radioButtonStyle">@style/CDK.Widget.RadioButton</item>
        <item name="materialButtonStyle">@style/CDK.Widget.Button.TextButton</item>
        <item name="materialButtonOutlinedStyle">@style/CDK.Widget.Button.TextButton.Outlined</item>
        <item name="editTextStyle">@style/CDK.Widget.EditText</item>
        <item name="checkboxStyle">@style/CDK.Widget.CheckBox</item>
        <item name="radioButtonStyle">@style/CDK.Widget.RadioButton</item>
        <item name="chipStyle">@style/CDK.Widget.Chip</item>
        <item name="recyclerViewStyle">@style/CDK.Widget.RecyclerView</item>
        <item name="smoothLayoutStyle">@style/CDK.Widget.Shapeable.DefaultRound</item>
        <item name="bottomSheetDialogTheme">@style/CDK.Dialog.Bottom</item>
        <item name="alertDialogTheme">@style/CDK.Dialog</item>
    </style>
</resources>